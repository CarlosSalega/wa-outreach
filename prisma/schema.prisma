generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Contact {
  id         String        @id @default(cuid())
  phone      String        @unique
  agencyName String
  status     String        @default("pending") // pending | active | done | opted_out
  campaignId String?
  campaign   Campaign?     @relation(fields: [campaignId], references: [id])
  queue      MessageQueue[]
  createdAt  DateTime      @default(now())
}

model Template {
  id        String     @id @default(cuid())
  name      String
  messages  String
  campaigns Campaign[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Campaign {
  id           String   @id @default(cuid())
  name         String
  status       String   @default("ACTIVE")
  pauseReason  String?
  templateId   String
  template     Template @relation(fields: [templateId], references: [id])
  delayMinSec  Int      @default(30)
  delayMaxSec  Int      @default(45)
  contacts     Contact[]
  queue        MessageQueue[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MessageQueue {
  id           String   @id @default(cuid())
  contactId    String
  campaignId   String
  messageOrder Int
  bodySnapshot String
  status       String   @default("PENDING")
  scheduledAt  DateTime
  sentAt       DateTime?
  errorMessage String?
  attempts     Int      @default(0)
  contact      Contact  @relation(fields: [contactId], references: [id])
  campaign     Campaign @relation(fields: [campaignId], references: [id])
  log          MessageLog?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status, scheduledAt])
}

model MessageLog {
  id             String       @id @default(cuid())
  messageQueueId String       @unique
  messageQueue   MessageQueue @relation(fields: [messageQueueId], references: [id])
  status         String
  sentAt         DateTime?
  deliveredAt    DateTime?
  readAt         DateTime?
  errorCode      String?
  createdAt      DateTime     @default(now())
}

model AppConfig {
  id                 String   @id @default(cuid())
  waAccountStartDate DateTime
  dailyLimit         Int      @default(50)
  sendWindowStart    Int      @default(9)
  sendWindowStartMin Int      @default(0)
  sendWindowEnd      Int      @default(19)
  sendWindowEndMin   Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
